{
  "name": "headlo-auth",
  "version": "0.1.0",
  "description": "Headlo Auth React SDK — HeadloProvider, hooks, SignInButton",
  "license": "Elastic-2.0",
  "homepage": "https://www.headlo.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/headlohq/headlo-auth"
  },
  "keywords": [
    "headlo",
    "auth",
    "authentication",
    "oauth",
    "pkce",
    "react"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types":   "./dist/index.d.ts",
      "import":  "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev":   "tsup --watch",
    "tsc":   "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "react":        "^19.2.5",
    "tsup":         "^8.5.1",
    "typescript":   "^6.0.3"
  }
}
